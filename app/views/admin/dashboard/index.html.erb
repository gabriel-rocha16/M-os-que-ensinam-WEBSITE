<div class="max-w-7xl mx-auto mt-10 px-4 pb-10">
  <% if current_usuario.gestor.present? %>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white p-6 rounded-lg shadow-sm border border-blue-100 flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-500">Alunos Pendentes</p>
          <p class="text-2xl font-bold text-gray-900"><%= @total_alunos_pendentes %></p>
        </div>
        <div class="p-3 bg-blue-50 text-blue-600 rounded-full">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
        </div>
      </div>
      
      <div class="bg-white p-6 rounded-lg shadow-sm border border-yellow-100 flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-500">Cursos em Revisão</p>
          <p class="text-2xl font-bold text-gray-900"><%= @total_cursos_revisao %></p>
        </div>
        <div class="p-3 bg-yellow-50 text-yellow-600 rounded-full">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
        </div>
      </div>

      <div class="bg-white p-6 rounded-lg shadow-sm border border-purple-100 flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-500">Instrutores Ativos</p>
          <p class="text-2xl font-bold text-gray-900"><%= @total_instrutores %></p>
        </div>
        <div class="p-3 bg-purple-50 text-purple-600 rounded-full">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
        </div>
      </div>
    </div>
  <% end %>

  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-gray-800">Oficina de Cursos</h1>
    <div class="flex space-x-4">
      <% if current_usuario.gestor.present? %>
        <%= link_to "Fila de Aprovação", admin_usuarios_path, class: "bg-purple-600 hover:bg-purple-700 text-white font-bold py-2 px-6 rounded-full shadow-md transition-colors" %>
      <% end %>
      <% if current_usuario.gestor.present? || current_usuario.instrutor.present? %>
        <%= link_to "+ Novo Curso", new_curso_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-full shadow-md transition-colors" %>
      <% end %>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow-md overflow-hidden border border-gray-100">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Curso</th>
          <% if current_usuario.gestor.present? %>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Autor</th>
          <% end %>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Ações</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @cursos.each do |curso| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="flex items-center">
                <div>
                  <div class="text-sm font-medium text-gray-900"><%= curso.nome %></div>
                  <div class="text-sm text-gray-500"><%= curso.area %></div>
                </div>
              </div>
            </td>
            <% if current_usuario.gestor.present? %>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-900"><%= curso.usuario&.nome || "Sistema" %></div>
              </td>
            <% end %>
            <td class="px-6 py-4 whitespace-nowrap">
              <% if curso.rascunho? %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">Rascunho</span>
              <% elsif curso.aguardando_aprovacao? %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">Em Revisão</span>
              <% else %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Publicado</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              <div class="flex justify-end items-center space-x-2">
                <% if curso.rascunho? && (current_usuario.gestor.present? || curso.usuario_id == current_usuario.id) %>
                  <%= button_to "🚀 Solicitar Aprovação", solicitar_aprovacao_admin_curso_path(curso), method: :patch, class: "bg-blue-100 text-blue-800 hover:bg-blue-200 px-3 py-1 rounded text-xs font-bold transition-colors cursor-pointer" %>
                <% end %>
                
                <% if curso.aguardando_aprovacao? && current_usuario.gestor.present? %>
                  <%= button_to "✅ Publicar", publicar_admin_curso_path(curso), method: :patch, class: "bg-green-100 text-green-800 hover:bg-green-200 px-3 py-1 rounded text-xs font-bold transition-colors cursor-pointer" %>
                  <%= button_to "❌ Rejeitar", rejeitar_admin_curso_path(curso), method: :patch, class: "bg-red-100 text-red-800 hover:bg-red-200 px-3 py-1 rounded text-xs font-bold transition-colors cursor-pointer" %>
                <% end %>

                <%= link_to "Editar", edit_curso_path(curso), class: "text-blue-600 hover:text-blue-900 ml-2" %>
                <%= link_to "Ver", curso_path(curso), class: "text-gray-600 hover:text-gray-900 ml-2" %>
              </div>
            </td>
          </tr>
        <% end %>
        
        <% if @cursos.empty? %>
          <tr>
            <td colspan="<%= current_usuario.gestor.present? ? 4 : 3 %>" class="px-6 py-10 text-center text-gray-500">
              <svg class="mx-auto h-12 w-12 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
              Nenhum curso encontrado.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
